# ============================================================
# ZABBIX PORTAL - Configurações do Backend
# Copie este arquivo para .env e preencha com seus dados
# ============================================================

# Servidor
PORT=3001
NODE_ENV=production

# JWT - gere uma chave aleatória: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque_por_uma_chave_secreta_forte_aqui
JWT_EXPIRES_IN=8h

# Zabbix API
ZABBIX_URL=http://SEU_ZABBIX/api_jsonrpc.php
ZABBIX_USER=portal_admin
ZABBIX_PASSWORD=sua_senha_aqui

# Token de API do Zabbix (recomendado - mais seguro que user/password)
ZABBIX_TOKEN=seu_token_aqui

# SQLite
DB_PATH=./db/portal.db

# Anthropic API - necessário para o Alfred IA (opcional)
# Obter em: https://console.anthropic.com
ANTHROPIC_API_KEY=
