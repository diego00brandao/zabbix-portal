# Servidor
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=troque_por_uma_chave_secreta_forte_aqui_2024
JWT_EXPIRES_IN=8h

# Zabbix API
ZABBIX_URL=http://SEU_ZABBIX_URL/zabbix/api_jsonrpc.php
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix

# SQLite (caminho do banco local)
DB_PATH=./db/portal.db
